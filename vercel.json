{
  "version": 2,
  "cleanUrls": true,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.js" },
    { "source": "/shared-ui/(.*)", "destination": "/shared-ui/$1" },
    { "source": "/images/(.*)", "destination": "/images/$1" },
    { "source": "/css/(.*)", "destination": "/css/$1" },
    { "source": "/js/(.*)", "destination": "/js/$1" }
  ]
}
